# open-brain environment configuration
# Copy this file to .env and fill in your values. Never commit .env to git.

# ─── Server ───────────────────────────────────────────────────────────────────

# Port to listen on (default: 8091)
PORT=8091

# Public HTTPS URL of this server — used in OAuth metadata and DNS rebinding protection.
# Must match the actual URL clients connect to (no trailing slash).
MCP_SERVER_URL=https://brain.example.com

# ─── Database ─────────────────────────────────────────────────────────────────

# Postgres connection string with pgvector extension.
# Required — no default. Must be a valid postgres URL with pgvector extension.
DATABASE_URL=postgresql://open_brain:CHANGE_ME@localhost:5432/open_brain

# ─── Auth ─────────────────────────────────────────────────────────────────────

# Username shown in the OAuth login form
AUTH_USER=your-username

# Password for the OAuth login form (minimum 8 characters)
AUTH_PASSWORD=changeme-min-8-chars

# Secret key for JWT signing (minimum 32 characters — use a random hex string)
# Generate one: openssl rand -hex 32
JWT_SECRET=changeme-min-32-hex-chars-replace-this-now

# Path to the OAuth clients JSON file (for static client registrations)
# In Docker this defaults to /app/clients.json — mount your file there.
CLIENTS_FILE=/app/clients.json

# ─── Embeddings (Voyage AI) ────────────────────────────────────────────────────

# Voyage AI API key — required for saving and searching memories
# Get yours at https://www.voyageai.com/
VOYAGE_API_KEY=your-voyage-api-key

# Embedding model to use (default: voyage-4)
VOYAGE_MODEL=voyage-4

# ─── LLM Provider (for refine_memories and metadata extraction) ───────────────

# Provider: "anthropic" (default) or "openrouter"
LLM_PROVIDER=anthropic

# Default model — used for all "small" calls: entity extraction,
# capture-router classification, tool-use observation extraction, and
# short session/worktree summaries. Must be valid for the chosen provider.
# Anthropic: claude-haiku-4-5-20251001, claude-sonnet-4-5, etc.
# OpenRouter cheap picks (all cheaper than Haiku 4.5):
#   google/gemini-2.5-flash-lite   ($0.10 in / $0.40 out, 1M ctx) — recommended
#   openai/gpt-4.1-mini            ($0.20 in / $0.80 out, 1M ctx) — strong JSON mode
#   qwen/qwen3-32b                 ($0.08 in / $0.24 out, 41K ctx) — best value
LLM_MODEL=claude-haiku-4-5-20251001

# OPTIONAL: dedicated model for the heavier /api/session-capture endpoint
# (up to ~8k chars input, 1024 output tokens). Falls back to LLM_MODEL if unset.
# Example: keep a cheap Flash Lite as LLM_MODEL for high-volume small calls and
# point LLM_MODEL_CAPTURE at a stronger model for full-conversation extraction.
# LLM_MODEL_CAPTURE=openai/gpt-4.1-mini

# API key for Anthropic (required when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your-anthropic-api-key

# API key for OpenRouter (required when LLM_PROVIDER=openrouter)
# OPENROUTER_API_KEY=your-openrouter-api-key

# ─── Plugin hooks ─────────────────────────────────────────────────────────────

# Comma-separated list of API keys for plugin/script access (optional).
# Each key gets memory + evolution scopes. No admin scope is ever granted to API keys.
# Generate a key: python -c "import secrets; print('ob_' + secrets.token_hex(20))"
API_KEYS=

# ─── Guards ───────────────────────────────────────────────────────────────────

# Daily memory write cap per-server. Set to 0 to disable.
MAX_MEMORIES_PER_DAY=500
