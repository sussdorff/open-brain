# Postgres
DATABASE_URL=postgresql://open_brain:password@localhost:5432/open_brain

# MCP Server
PORT=8091
MCP_SERVER_URL=https://your-mcp-server.example.com

# Auth
AUTH_USER=malte
AUTH_PASSWORD=changeme-min-8-chars
JWT_SECRET=changeme-min-32-hex-chars

# Clients
CLIENTS_FILE=/opt/open-brain/clients.json

# Embeddings (Voyage AI)
VOYAGE_API_KEY=your-voyage-api-key
VOYAGE_MODEL=voyage-4

# LLM for metadata extraction / refinement
# Provider: "anthropic" (default) or "openrouter"
LLM_PROVIDER=anthropic
LLM_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_API_KEY=your-anthropic-api-key
# OPENROUTER_API_KEY=your-openrouter-api-key
