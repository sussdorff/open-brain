        <li><a href="https://fhir-community.example/events/connectathon-mai">
            FHIR Connectathon Mai 2026</a> — 19.–20. Mai, München</li>
        <li><a href="https://fhir-community.example/events/webinar-april">
            Webinar: FHIR R5 Migration Praktisch</a> — 28. April, Online</li>
        <li><a href="https://fhir-community.example/events/workshop-berlin">
            Workshop: Terminologie-Binding in der Praxis</a> — 5. Mai, Berlin</li>
      </ul>

